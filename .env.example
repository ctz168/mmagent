# MMAgent Environment Configuration
# Copy this file to .env and customize as needed

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# LLM Configuration
LLM_GATEWAY_URL=http://10.138.255.202:8080
ANTHROPIC_BASE_URL=http://127.0.0.1:8765
DEFAULT_MODEL=claude-sonnet-4-5
CLAUDE_CODE_ENTRYPOINT=sdk-py-client

# Workspace Configuration
WORKSPACE_DIR=/workspace
PYTHONPATH=/workspace/mmagent:/app

# Engine Configuration
ENGINE_DIR=/workspace/mmagent/engine

# Claude Code CLI Path (optional, will auto-detect if not set)
# CLAUDE_CODE_CLI_PATH=/workspace/mmagent/engine/claude

# Browser Configuration
DISPLAY=:99
PLAYWRIGHT_BROWSERS_PATH=/opt/playwright-browsers

# Tool Configuration
BASH_TIMEOUT=300
MAX_FILE_SIZE=10485760

# Python Environment (optional)
# UV_INDEX_URL=http://mirrors.cloud.aliyuncs.com/pypi/simple
# UV_PROJECT_ENVIRONMENT=/tmp/.venv
